{
  "name": "yingdao-dashboard",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "start:backend": "npm --workspace apps/backend run start:dev",
    "start:frontend": "npm --workspace apps/frontend run dev -- --host",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:backend": "npm --workspace apps/backend run build",
    "build:frontend": "npm --workspace apps/frontend run build",
    "build:desktop": "npm run build:backend && npm run build:frontend",
    "desktop": "npm run build:desktop && electron .",
    "package": "npm run build:desktop && electron-builder",
    "package:mac": "npm run build:desktop && electron-builder --mac",
    "package:win": "npm run build:desktop && electron-builder --win"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "main": "desktop/electron-main.cjs",
  "build": {
    "appId": "com.simone.yingdao-dashboard",
    "productName": "影刀调度运维台",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "apps/frontend/dist/**/*",
      "apps/backend/dist/**/*",
      "apps/backend/package.json",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "version": "0.1.0",
  "description": "Yingdao desktop dashboard",
  "author": "Simone"
}
